# Copy to .env (in the skill root, or your project root) and fill in.

# WeChat Official Account — 公众号后台 → 开发 → 基本配置
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# OpenAI — used only when generating cover images with --gen-cover
OPENAI_API_KEY=
# Optional: gpt-image-2 (default), gpt-image-1, or dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-2
